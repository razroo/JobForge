{
  "$schema": "https://opencode.ai/config.json",
  "mcpServers": {
    "geometra": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@geometra/mcp"
      ],
      "env": {}
    },
    "gmail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/shinzo-labs/gmail-mcp.git"
      ],
      "env": {}
    }
  },
  "instructions": [
    "modes/*.md",
    "data/*.md",
    "templates/*.md",
    "batch/*.md",
    "templates/states.yml"
  ]
}