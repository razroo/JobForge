{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "geometra": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@geometra/mcp"
      ],
      "env": {}
    },
    "gmail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@razroo/gmail-mcp"
      ],
      "env": {}
    }
  },
  "instructions": [
    "modes/*.md",
    "data/*.md",
    "templates/*.md",
    "batch/*.md",
    "templates/states.yml"
  ]
}